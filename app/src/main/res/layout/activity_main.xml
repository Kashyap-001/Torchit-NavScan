<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Brand Header -->

    <!-- Scanner Control Button -->
    <TextView
        android:id="@+id/txtHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:text="Torchit NavScan Dashboard"
        android:textColor="?attr/colorPrimary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:contentDescription="Button to scan for nearby Saarthi assistive devices"
        android:padding="12dp"
        android:text="Start Hardware Scan"
        android:textSize="16sp" />

    <!-- Accessible List View Component -->
    <ListView
        android:id="@+id/lstDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="List of discovered Bluetooth hardware signals"
        android:divider="#CCCCCC"
        android:dividerHeight="1dp" />

</LinearLayout>
